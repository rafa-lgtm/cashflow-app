# Renombra a ".env" y rellena tus datos reales.

# Proxy Oxylabs — cada dato por separado (soporta + @ : y otros simbolos)
PROXY_HOST=isp.oxylabs.io
PROXY_PORT=8001
PROXY_USER=tu_usuario_oxylabs
PROXY_PASS=tu_password_con_simbolos+incluidos

# Credenciales Airwallex
AIRWALLEX_CLIENT_ID=tu_client_id
AIRWALLEX_API_KEY=tu_api_key
